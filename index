];

let activeTab = "Hammasi";

function buildTabs() {
  const wrap = document.getElementById("tabsWrap");
  wrap.innerHTML = "";
  Object.keys(CATS).forEach(k => {
    const b = document.createElement("button");
    b.className = "tab" + (k === activeTab ? " active" : "");
    b.textContent = k;
    b.onclick = () => { activeTab = k; buildTabs(); render(); };
    wrap.appendChild(b);
  });
}

function highlight(text, q) {
  if (!q) return text;
  const re = new RegExp(`(${q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')})`, 'gi');
  return text.replace(re, '<mark style="background:rgba(124,106,247,0.3);color:inherit;border-radius:3px;">$1</mark>');
}

function render() {
  const q = document.getElementById("searchInput").value.trim().toLowerCase();
  const catFilter = CATS[activeTab];
  const filtered = DATA.filter(d => {
    const matchC = !catFilter || d.cat === catFilter;
    const matchQ = !q || d.kw.toLowerCase().includes(q) ||
                       d.uz.toLowerCase().includes(q) ||
                       d.desc.toLowerCase().includes(q);
    return matchC && matchQ;
  });

  document.getElementById("resultCount").textContent =
    filtered.length + " ta so'z" + (q ? ` — "${q}" bo'yicha` : "");

  const grid = document.getElementById("grid");
  if (!filtered.length) {
    grid.innerHTML = '<div class="empty">Hech narsa topilmadi 🔍</div>';
    return;
  }

  grid.innerHTML = filtered.map(d => `
    <div class="card c-${d.cat}" onclick="this.classList.toggle('open')">
      <div class="card-header">
        <span class="keyword">${highlight(d.kw, q)}</span>
        <span class="badge badge-${d.cat}">${CAT_LABEL[d.cat]}</span>
      </div>
      <div class="trans">${highlight(d.uz, q)}</div>
      <div class="desc">${d.desc}</div>
      <div class="example-block">
        <div class="example-label">MISOL</div>
        <div class="example-code">${d.ex.replace(/</g,'&lt;').replace(/>/g,'&gt;')}</div>
      </div>
      <div class="toggle-hint">▼ kod misolini ko'rish uchun bosing</div>
    </div>
  `).join('');
}

document.getElementById("searchInput").addEventListener("input", render);

buildTabs();
render();
</script>
